# ===========================================
# Oreko Web App Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Oreko
ALLOWED_REGISTRATION_EMAIL=

# Database (PostgreSQL)
DATABASE_URL="postgresql://oreko:oreko@localhost:5432/oreko?schema=public"

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # Generate with: openssl rand -base64 32
AUTH_TRUST_HOST=true

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Low #36: Removed STRIPE_PUBLISHABLE_KEY (wrong name). Use NEXT_PUBLIC_ version below.

# Email — choose one provider. Microsoft Graph takes precedence when fully configured.
# Option 1: Microsoft 365 / Graph (recommended for Exchange Online)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER=info@example.com

# Internal recipients for payment and overdue invoice alerts (comma-separated)
ADMIN_ALERT_EMAILS=admin1@example.com,admin2@example.com

# Option 2: Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@oreko.dev
EMAIL_REPLY_TO=

# Option 3: SMTP (for providers that still accept password authentication)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# File Storage
STORAGE_PROVIDER=local          # local | supabase | s3 | cloudflare
STORAGE_LOCAL_PATH=./uploads
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_URL=

# Supabase Storage (required when STORAGE_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Stripe (public key for client-side checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Demo Mode (optional)
DEMO_USER_EMAIL=

# Cron Jobs (optional — secret for /api/cron endpoints)
CRON_SECRET=

# PDF Generation (optional — Puppeteer path override)
# PUPPETEER_EXECUTABLE_PATH=

# Social Links (optional — shown in landing page footer)
# NEXT_PUBLIC_GITHUB_URL=https://github.com/orekoapp/oreko
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_DISCORD_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
